{
  "description": "A tool to play with and train large language models",
  "keywords": [
    "LLM",
    "LocalLLaMA"
  ],
  "homepage": "https://lab.cloud",
  "bugs": {
    "url": "https://lab.cloud"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transformerlab/transformerlab-app.git"
  },
  "license": "MIT",
  "author": {
    "name": "Ali Asaria",
    "email": "ali",
    "url": "https://lab.cloud"
  },
  "contributors": [
    {
      "name": "Tony Salomone",
      "email": "dadmobile",
      "url": "https://github.com/dadmobile"
    }
  ],
  "version": "0.38.0",
  "scripts": {
    "build": "dotenv -e .env -- cross-env NODE_ENV=production tsx node_modules/webpack/bin/webpack.js --config ./.erb/configs/webpack.config.cloud.prod.ts",
    "build:multiuser": "cross-env NODE_ENV=production tsx node_modules/webpack/bin/webpack.js --config ./.erb/configs/webpack.config.cloud.prod.ts",
    "check-ports": "! lsof -i :1212 -i :8338",
    "lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
    "start": "dotenv -e .env -- cross-env NODE_ENV=development tsx node_modules/webpack-dev-server/bin/webpack-dev-server.js --config ./.erb/configs/webpack.config.cloud.dev.ts",
    "dev": "npm run check-ports && concurrently -k -n FRONTEND,API -c cyan,magenta \"npm run start\" \"npm run api:start\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\" \"transformerlab-docs/**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx,yml,yaml}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\" \"transformerlab-docs/**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx,yml,yaml}\"",
    "format:api": "prettier --write \"api/transformerlab/plugins/**/*.json\"",
    "api:install": "cd api && ./install.sh",
    "api:start": "cd api && ./run.sh",
    "docker-test:up": "docker compose -f docker-compose.test.yml up -d --build --wait",
    "docker-test:down": "docker compose -f docker-compose.test.yml down",
    "docker-test:logs": "docker compose -f docker-compose.test.yml logs -f",
    "docker-test:playwright": "npm run docker-test:up && npx playwright test; npm run docker-test:down"
  },
  "browserslist": [],
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
